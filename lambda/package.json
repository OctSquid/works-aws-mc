    "@aws-sdk/client-route-53": "^3.600.0",
    "@aws-sdk/client-ssm": "^3.600.0",
    "@aws-sdk/lib-dynamodb": "^3.600.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
