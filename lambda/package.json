{
  "name": "mc-lambda",
  "version": "0.1.0",
  "private": true,
  "description": "Lambda functions for the on-demand Minecraft server control plane",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && node esbuild.config.mjs",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.600.0",
    "@aws-sdk/client-ec2": "^3.600.0",
