{
  "$schema": "./plugins.schema.json",
  "plugins": [
    {
      "name": "Geyser-Spigot",
      "source": "geysermc",
      "project": "geyser"
    },
    {
      "name": "floodgate",
      "source": "geysermc",
      "project": "floodgate",
      "preserve": ["plugins/floodgate/key.pem"]
    },
    {
      "name": "ViaVersion",
      "source": "hangar",
      "id": "ViaVersion",
      "version": "latest"
    },
    {
      "name": "GeyserSkinManager",
      "source": "github",
      "repo": "MusclePr/GeyserSkinManager",
      "version": "1.10-SNAPSHOT",
      "assetPattern": "^GeyserSkinManager-Spigot\\.jar$",
      "preserve": ["plugins/GeyserSkinManager/users/*"]
    }
  ]
}
