{
  "name": "aws-mc-server",
  "private": true,
  "description": "リポジトリ共通の Lint / Format ツール (oxlint, oxfmt)",
  "scripts": {
    "lint": "oxlint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,ts,mts,cts}": [
      "oxlint",
      "oxfmt"
    ],
    "*.{json,jsonc}": "oxfmt"
  },
  "engines": {
    "node": ">=22"
  }
}
