# ローカル開発・セットアップ用の環境変数。mise が全タスクに自動注入する（mise.toml の _.file）。
# このファイルを .env にコピーして値を埋める。.env は gitignore 済み・絶対にコミットしないこと。

# --- Discord (Developer Portal https://discord.com/developers/applications) ---
# General Information → Application ID
DISCORD_APPLICATION_ID=
# General Information → Public Key（interactions の署名検証用。setup:secrets が SSM へ投入）
DISCORD_PUBLIC_KEY=
# Bot → Token（スラッシュコマンド登録・setup:secrets が SSM へ投入）
DISCORD_BOT_TOKEN=
# コマンドを登録するサーバー（ギルド）の ID（Discord の開発者モードで右クリック→ID コピー）
DISCORD_GUILD_ID=
# 通知先チャンネルの Webhook URL（チャンネル設定 → 連携サービス → Webhook）
DISCORD_WEBHOOK_URL=

# --- 任意 ---
# GitHub API のレート制限緩和（プラグインの GitHub Releases 取得時）
GITHUB_TOKEN=
# CurseForge 配布プラグインを使う場合のみ（https://console.curseforge.com/）
CURSEFORGE_API_KEY=
